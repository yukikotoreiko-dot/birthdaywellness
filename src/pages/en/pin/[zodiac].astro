    tagline: 'Compassionate Healer',
    url: '/en/march/15/',
  },
};

export async function getStaticPaths() {
  const pins: Record<string, ZodiacPin> = {
    aries:       { name: 'Aries',       symbol: '♈', dateRange: 'March 21 — April 19',       element: 'Fire',  ruler: 'Mars',    tagline: 'Born to Begin',          url: '/en/april/15/' },
    taurus:      { name: 'Taurus',      symbol: '♉', dateRange: 'April 20 — May 20',         element: 'Earth', ruler: 'Venus',   tagline: 'Sacred Embodiment',      url: '/en/may/15/' },
    gemini:      { name: 'Gemini',      symbol: '♊', dateRange: 'May 21 — June 21',          element: 'Air',   ruler: 'Mercury', tagline: 'Voice of Connection',    url: '/en/june/15/' },
    cancer:      { name: 'Cancer',      symbol: '♋', dateRange: 'June 22 — July 22',         element: 'Water', ruler: 'Moon',    tagline: 'Sacred Refuge',          url: '/en/july/15/' },
    leo:         { name: 'Leo',         symbol: '♌', dateRange: 'July 23 — August 22',       element: 'Fire',  ruler: 'Sun',     tagline: 'Born to Shine',          url: '/en/august/15/' },
    virgo:       { name: 'Virgo',       symbol: '♍', dateRange: 'August 23 — September 22',  element: 'Earth', ruler: 'Mercury', tagline: 'The Devoted Artisan',    url: '/en/september/15/' },
    libra:       { name: 'Libra',       symbol: '♎', dateRange: 'September 23 — October 23', element: 'Air',   ruler: 'Venus',   tagline: 'Beauty as Truth',        url: '/en/october/15/' },
    scorpio:     { name: 'Scorpio',     symbol: '♏', dateRange: 'October 24 — November 22',  element: 'Water', ruler: 'Pluto',   tagline: 'Sovereign Alchemy',      url: '/en/november/15/' },
    sagittarius: { name: 'Sagittarius', symbol: '♐', dateRange: 'November 23 — December 21', element: 'Fire',  ruler: 'Jupiter', tagline: 'Visionary Pilgrim',      url: '/en/november/25/' },
    capricorn:   { name: 'Capricorn',   symbol: '♑', dateRange: 'December 22 — January 19',  element: 'Earth', ruler: 'Saturn',  tagline: 'The Quiet Sage',         url: '/en/january/15/' },
    aquarius:    { name: 'Aquarius',    symbol: '♒', dateRange: 'January 20 — February 18',  element: 'Air',   ruler: 'Uranus',  tagline: 'Visionary Engineer',     url: '/en/february/15/' },
    pisces:      { name: 'Pisces',      symbol: '♓', dateRange: 'February 19 — March 20',    element: 'Water', ruler: 'Neptune', tagline: 'Compassionate Healer',   url: '/en/march/15/' },
  };
  return Object.entries(pins).map(([key, info]) => ({
    params: { zodiac: key },
    props: { info },
  }));
}

const { info } = Astro.props as { info: ZodiacPin };
---

<PinLayout title={`${info.name} Soul Reading - Pinterest Pin`}>
  <article
    style="width: 1000px; height: 1500px; position: relative; overflow: hidden; background: linear-gradient(180deg, #0a0a2e 0%, #1a0f3a 30%, #2d1b4e 55%, #4a2a5e 75%, #c97b6a 92%, #f4a672 100%); box-shadow: 0 30px 80px rgba(0,0,0,0.3); border-radius: 8px;"
  >
    <!-- 星屑装飾（上部左） -->
    <div style="position: absolute; top: 80px; left: 80px;">
      <svg width="120" height="120" viewBox="0 0 120 120" style="filter: drop-shadow(0 0 8px rgba(251,191,36,0.6));">
        <g fill="#fbbf24">
          <path d="M30 30 L33 45 L48 48 L33 51 L30 66 L27 51 L12 48 L27 45 Z" opacity="0.9"/>
          <path d="M70 20 L72 30 L82 32 L72 34 L70 44 L68 34 L58 32 L68 30 Z" opacity="0.7"/>
          <circle cx="90" cy="80" r="2" opacity="0.8"/>
          <circle cx="20" cy="80" r="1.5" opacity="0.7"/>
          <circle cx="100" cy="50" r="1.5" opacity="0.6"/>
        </g>
      </svg>
    </div>

    <!-- 月相アーチ -->
    <div style="position: absolute; top: 120px; left: 50%; transform: translateX(-50%); width: 800px;">
      <svg width="800" height="280" viewBox="0 0 800 280">
        <defs>
          <radialGradient id="moonGlow">
            <stop offset="0%" stop-color="#f5f5f5" stop-opacity="1"/>
            <stop offset="100%" stop-color="#bbbbbb" stop-opacity="0.5"/>
          </radialGradient>
        </defs>
        <!-- 8 phases of moon along an arch -->
        <g fill="url(#moonGlow)" style="filter: drop-shadow(0 0 10px rgba(255,255,255,0.4));">
          <!-- 左端：三日月 -->
          <g transform="translate(50, 200)">
            <circle r="35" fill="#0a0a2e"/>
            <path d="M -25 0 A 30 30 0 0 1 25 0 A 22 22 0 0 0 -25 0 Z" fill="#e8e8e8"/>
          </g>
          <!-- 半月 -->
          <g transform="translate(150, 140)">
            <circle r="35" fill="#0a0a2e"/>
            <path d="M 0 -32 A 32 32 0 0 1 0 32 Z" fill="#e8e8e8"/>
          </g>
          <!-- 三日月（増） -->
          <g transform="translate(260, 90)">
            <circle r="38" fill="#0a0a2e"/>
            <path d="M -15 -35 A 35 35 0 0 1 -15 35 A 28 28 0 0 0 -15 -35 Z" fill="#e8e8e8"/>
          </g>
          <!-- 満月 -->
          <g transform="translate(400, 70)">
            <circle r="42" fill="#e8e8e8"/>
            <circle r="42" fill="url(#moonGlow)"/>
          </g>
          <!-- 三日月（減） -->
          <g transform="translate(540, 90)">
            <circle r="38" fill="#0a0a2e"/>
            <path d="M 15 -35 A 35 35 0 0 0 15 35 A 28 28 0 0 1 15 -35 Z" fill="#e8e8e8"/>
          </g>
          <!-- 半月 -->
          <g transform="translate(650, 140)">
            <circle r="35" fill="#0a0a2e"/>
            <path d="M 0 -32 A 32 32 0 0 0 0 32 Z" fill="#e8e8e8"/>
          </g>
          <!-- 右端：三日月 -->
          <g transform="translate(750, 200)">
            <circle r="35" fill="#0a0a2e"/>
            <path d="M 25 0 A 30 30 0 0 0 -25 0 A 22 22 0 0 1 25 0 Z" fill="#e8e8e8"/>
          </g>
        </g>
      </svg>
    </div>

    <!-- 上部タイトル -->
    <div style="position: absolute; top: 500px; left: 0; right: 0; text-align: center;">
      <p style="font-family: 'Cinzel', 'Playfair Display', serif; font-size: 16px; letter-spacing: 0.5em; color: #fbbf24; margin: 0; text-transform: uppercase;">
        ✦  Are You a  ✦
      </p>
      <h1 style="font-family: 'Playfair Display', 'Cormorant Garamond', serif; font-style: italic; font-size: 110px; font-weight: 600; color: #ffffff; margin: 20px 0 10px; line-height: 1; text-shadow: 0 0 30px rgba(251,191,36,0.3);">
        {info.name}?
      </h1>
      <p style="font-family: 'Cormorant Garamond', serif; font-size: 24px; letter-spacing: 0.2em; color: rgba(255,255,255,0.85); margin: 0; font-weight: 400;">
        {info.dateRange}
      </p>
    </div>

    <!-- 中央：星座シンボル＋タグライン -->
    <div style="position: absolute; top: 800px; left: 0; right: 0; text-align: center;">
      <div style="font-family: 'Noto Sans Symbols 2', 'Apple Symbols', serif; font-size: 120px; color: #fbbf24; line-height: 1; text-shadow: 0 0 40px rgba(251,191,36,0.7), 0 0 80px rgba(251,191,36,0.4);">
        {info.symbol}
      </div>
      <p style="font-family: 'Playfair Display', serif; font-style: italic; font-size: 38px; color: #f7e7c5; margin: 30px auto 0; max-width: 700px; line-height: 1.3;">
        Discover Your<br/>
        Soul Mission
      </p>
    </div>

    <!-- CTAボックス -->
    <div style="position: absolute; bottom: 280px; left: 50%; transform: translateX(-50%); text-align: center;">
      <div style="display: inline-block; padding: 18px 50px; background: linear-gradient(135deg, rgba(251,191,36,0.95) 0%, rgba(217,119,6,0.95) 100%); border-radius: 100px; box-shadow: 0 10px 30px rgba(0,0,0,0.3);">
        <p style="font-family: 'Cinzel', serif; font-size: 22px; letter-spacing: 0.25em; color: #2d1b4e; margin: 0; font-weight: 600;">
          READ YOUR FREE READING →
        </p>
      </div>
      <p style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 20px; color: rgba(255,255,255,0.8); margin: 25px 0 0;">
        Premium Soul Reading available — $2.99
      </p>
    </div>

    <!-- 山シルエット -->
    <svg style="position: absolute; bottom: 0; left: 0;" width="1000" height="220" viewBox="0 0 1000 220" preserveAspectRatio="none">
      <path d="M0 220 L0 130 L120 80 L220 110 L340 60 L460 100 L580 50 L700 90 L820 70 L920 110 L1000 90 L1000 220 Z" fill="#1a0f3a" opacity="0.95"/>
      <path d="M0 220 L0 160 L150 130 L280 150 L420 120 L560 140 L700 110 L850 140 L1000 130 L1000 220 Z" fill="#0a0a2e" opacity="0.9"/>
    </svg>

    <!-- 星屑装飾（右下） -->
    <div style="position: absolute; bottom: 220px; right: 60px;">
      <svg width="100" height="100" viewBox="0 0 100 100" style="filter: drop-shadow(0 0 8px rgba(251,191,36,0.6));">
        <g fill="#fbbf24">
          <path d="M50 20 L53 38 L70 40 L53 42 L50 60 L47 42 L30 40 L47 38 Z" opacity="0.9"/>
          <path d="M75 65 L77 73 L85 75 L77 77 L75 85 L73 77 L65 75 L73 73 Z" opacity="0.75"/>
          <circle cx="20" cy="50" r="2" opacity="0.7"/>
          <circle cx="85" cy="30" r="1.5" opacity="0.6"/>
        </g>
      </svg>
    </div>

    <!-- ブランド名（最下部） -->
    <div style="position: absolute; bottom: 30px; left: 0; right: 0; text-align: center;">
      <p style="font-family: 'Cinzel', serif; font-size: 14px; letter-spacing: 0.5em; color: rgba(255,255,255,0.7); margin: 0; text-transform: uppercase;">
        Birthday Wellness · birthdaywellness.com
      </p>
    </div>

    <!-- 散布星 -->
    <div style="position: absolute; top: 600px; left: 100px; color: rgba(255,255,255,0.6); font-size: 14px;">✦</div>
    <div style="position: absolute; top: 720px; right: 120px; color: rgba(251,191,36,0.7); font-size: 18px;">✧</div>
    <div style="position: absolute; top: 900px; left: 150px; color: rgba(255,255,255,0.5); font-size: 12px;">·</div>
    <div style="position: absolute; top: 950px; right: 180px; color: rgba(251,191,36,0.6); font-size: 16px;">✦</div>
    <div style="position: absolute; top: 1050px; left: 80px; color: rgba(255,255,255,0.7); font-size: 14px;">✧</div>
    <div style="position: absolute; top: 1100px; right: 100px; color: rgba(255,255,255,0.5); font-size: 12px;">·</div>
  </article>
</PinLayout>
