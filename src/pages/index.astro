---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = '誕生日占い × 薬剤師監修ウェルネス | Birthday Wellness';
const description =
  '生年月日を入れるだけで、366日それぞれの性格・恋愛・仕事・相性・ラッキーアイテムに加え、薬剤師監修の体質傾向・健康ラッキーフード・セルフケアまでがわかる誕生日占いサイト。';
---

<BaseLayout title={title} description={description} lang="ja" currentPath="/">
  <div class="space-y-10">
    <!-- ヒーロー -->
    <section class="text-center space-y-4 py-6">
      <p class="text-xs tracking-widest text-purple-600 font-medium">BIRTHDAY WELLNESS</p>
      <h1 class="text-3xl md:text-4xl font-bold text-purple-900 leading-tight">
        あなたの誕生日から<br />
        <span class="text-pink-600">性格・運命・体質</span>を知る
      </h1>
      <p class="text-slate-600 max-w-md mx-auto leading-relaxed">
        366日それぞれの占いに、<br class="md:hidden" />
        <strong class="text-emerald-700">薬剤師監修の体質・セルフケア</strong>を加えた<br class="md:hidden" />
        新しい誕生日占いサイトです。
      </p>
    </section>

    <!-- 入力フォーム -->
    <section class="bg-white/80 backdrop-blur rounded-3xl p-8 shadow-lg border border-purple-100">
      <h2 class="text-lg font-bold text-purple-900 mb-6 text-center">
        生年月日（月日）を選んで占う
      </h2>
      <form id="birthdayForm" class="space-y-4">
        <div class="flex items-center justify-center gap-3">
          <select
            id="month"
            class="px-4 py-3 rounded-xl border border-purple-200 bg-white text-lg font-medium focus:outline-none focus:ring-2 focus:ring-purple-400"
            required
          >
            <option value="">月</option>
            {Array.from({ length: 12 }, (_, i) => (
              <option value={i + 1}>{i + 1}月</option>
            ))}
          </select>
          <span class="text-slate-400">/</span>
          <select
            id="day"
            class="px-4 py-3 rounded-xl border border-purple-200 bg-white text-lg font-medium focus:outline-none focus:ring-2 focus:ring-purple-400"
            required
          >
            <option value="">日</option>
            {Array.from({ length: 31 }, (_, i) => (
              <option value={i + 1}>{i + 1}日</option>
            ))}
          </select>
        </div>
        <button
          type="submit"
          class="w-full py-4 bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700 text-white font-bold rounded-2xl text-lg shadow-md hover:shadow-lg transition transform hover:-translate-y-0.5"
        >
          ✨ 占う
        </button>
      </form>
      <p id="formError" class="hidden text-sm text-rose-600 text-center mt-3"></p>
    </section>

    <!-- 特徴 -->
    <section class="grid md:grid-cols-3 gap-4">
      <div class="bg-white/70 rounded-2xl p-5 text-center space-y-2">
        <div class="text-3xl">🌟</div>
        <p class="text-sm font-semibold text-purple-900">366日 完全網羅</p>
        <p class="text-xs text-slate-600">西洋占星術＋数秘術＋誕生花＋誕生石を統合</p>
      </div>
      <div class="bg-white/70 rounded-2xl p-5 text-center space-y-2">
        <div class="text-3xl">💊</div>
        <p class="text-sm font-semibold text-purple-900">薬剤師監修</p>
        <p class="text-xs text-slate-600">体質傾向・健康フード・セルフケアまで詳しく</p>
      </div>
      <div class="bg-white/70 rounded-2xl p-5 text-center space-y-2">
        <div class="text-3xl">🌎</div>
        <p class="text-sm font-semibold text-purple-900">日英2言語</p>
        <p class="text-xs text-slate-600">海外の方にも"Japanese Wellness"を発信</p>
      </div>
    </section>
  </div>

  <script is:inline>
    const monthSlugs = [
      'january', 'february', 'march', 'april', 'may', 'june',
      'july', 'august', 'september', 'october', 'november', 'december'
    ];

    const form = document.getElementById('birthdayForm');
    const errorEl = document.getElementById('formError');

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const month = parseInt(document.getElementById('month').value, 10);
      const day = parseInt(document.getElementById('day').value, 10);

      if (!month || !day) {
        errorEl.textContent = '月と日を選んでください';
        errorEl.classList.remove('hidden');
        return;
      }

      // 月ごとの日数チェック
      const daysInMonth = [31, 29, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31];
      if (day > daysInMonth[month - 1]) {
        errorEl.textContent = `${month}月は${daysInMonth[month - 1]}日までです`;
        errorEl.classList.remove('hidden');
        return;
      }

      errorEl.classList.add('hidden');
      const slug = monthSlugs[month - 1];
      window.location.href = `/${slug}/${day}/`;
    });
  </script>
</BaseLayout>
